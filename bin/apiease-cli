#!/usr/bin/env bash

set -euo pipefail

script_source_path="${BASH_SOURCE[0]}"

while [ -L "${script_source_path}" ]; do
  script_directory_path="$(cd -P "$(dirname "${script_source_path}")" && pwd)"
  script_source_path="$(readlink "${script_source_path}")"

  if [[ "${script_source_path}" != /* ]]; then
    script_source_path="${script_directory_path}/${script_source_path}"
  fi
done

script_directory_path="$(cd -P "$(dirname "${script_source_path}")" && pwd)"

exec node "${script_directory_path}/apiease-cli.js" "$@"
