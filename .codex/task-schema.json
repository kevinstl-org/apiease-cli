{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CodexTask",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "text",
    "goalId",
    "goal",
    "project",
    "status",
    "priority"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "goalId": {
      "type": "string",
      "minLength": 1
    },
    "text": {
      "type": "string",
      "minLength": 1
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "project": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "initialized",
        "pending-approval",
        "approved",
        "building",
        "complete"
      ]
    },
    "priority": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "urgent"
      ]
    },
    "sequenceIndex": {
      "type": "integer"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "createdBy": {
      "type": "string"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "context": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "acceptanceCriteria": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "codexSettings": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "workingDirectory": {
          "type": "string"
        },
        "branchStrategy": {
          "type": "string",
          "enum": [
            "current",
            "feature_per_task"
          ]
        },
        "maxRuns": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "summary": {
          "type": "string"
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "completedAt": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    }
  }
}
